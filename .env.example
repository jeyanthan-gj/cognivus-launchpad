# ══════════════════════════════════════════════════════════════════════════════
# Cognivus — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control — it is in .gitignore.
#
# Variable naming convention:
#   VITE_*   — safe to expose in the browser (bundled by Vite into client JS)
#   (no prefix) — server-only secrets, read via process.env, never bundled
# ══════════════════════════════════════════════════════════════════════════════

# ── Supabase: public credentials (safe for browser) ──────────────────────────
# Supabase dashboard → Project Settings → API → Project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase dashboard → Project Settings → API → anon/public key
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase dashboard → Project Settings → General → Reference ID (e.g. nvqcqzy...)
VITE_SUPABASE_PROJECT_ID=your-project-ref

# ── Supabase: server-only secret (NEVER expose to browser) ───────────────────
# Supabase dashboard → Project Settings → API → service_role key
# WARNING: This key bypasses ALL Row Level Security. Treat like a root password.
# Set in Netlify: Site settings → Environment variables (not in netlify.toml)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Duplicate of VITE_SUPABASE_URL for server functions that read process.env directly.
# Must match VITE_SUPABASE_URL exactly.
SUPABASE_URL=https://your-project-ref.supabase.co

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call server functions.
# Production: your apex domain only.  Local dev: http://localhost:5173
ALLOWED_ORIGINS=https://cognivus.ai

# ── Node environment ──────────────────────────────────────────────────────────
# Set automatically by Netlify for production deploys.
# Override locally for testing production behaviour.
# NODE_ENV=production

# ── Admin provisioning (scripts/provision-admin.ts only) ─────────────────────
# Used ONLY when running the provisioning script locally.
# Never set these in Netlify environment variables.
# Clear your shell history after use: history -d <line_number>
# ADMIN_EMAIL=admin@yourdomain.com
# ADMIN_PASSWORD=YourStr0ng!Password123
